<%- include("partials/header", { title, isAuthenticated }) %>
<section class="layout-grid">
  <article class="card form-card reveal">
    <h2>Generate Test Cases</h2>
    <p>
      Paste your assignment details and a trusted reference implementation. The system builds
      edge-case-heavy tests and repeats patterns to meet your requested count.
    </p>

    <% if (error) { %>
    <div class="alert"><%= error %></div>
    <% } %>

    <form method="post" action="/dashboard/generate" class="stack-form">
      <label>
        Challenge Title
        <input
          type="text"
          name="challengeTitle"
          required
          value="<%= formData.challengeTitle %>"
          placeholder="Ex: Two Sum Variant"
        />
      </label>

      <div class="row-two">
        <label>
          Language
          <select name="language">
            <option value="python" <%= formData.language === 'python' ? 'selected' : '' %>>
              Python
            </option>
            <option value="javascript" <%= formData.language === 'javascript' ? 'selected' : '' %>>
              JavaScript
            </option>
            <option value="java" <%= formData.language === 'java' ? 'selected' : '' %>>Java</option>
            <option value="cpp" <%= formData.language === 'cpp' ? 'selected' : '' %>>C++</option>
          </select>
        </label>

        <label>
          Required Test Cases
          <input
            type="number"
            name="requiredCount"
            min="1"
            max="500"
            value="<%= formData.requiredCount %>"
            required
          />
        </label>
      </div>

      <div class="row-two">
        <label>
          Function Name
          <input
            type="text"
            name="functionName"
            value="<%= formData.functionName %>"
            placeholder="solve"
          />
        </label>

        <label class="checkbox-row">
          <span>Run reference code now</span>
          <input
            type="checkbox"
            name="runCodeEnabled"
            value="yes"
            <%= formData.runCodeEnabled ? 'checked' : '' %>
          />
        </label>
      </div>

      <p class="helper-note">
        Runtime runner entry point: your code must define the function above. If you paste a
        class-only snippet (like <strong>DisjointSets</strong>), add a wrapper function such as
        <strong>solve(input_data)</strong> that uses the class and returns final output.
      </p>

      <label>
        Directions / Problem Statement
        <textarea
          name="directions"
          rows="8"
          required
          placeholder="Describe constraints, expected behavior, input/output format, and error handling rules."
        ><%= formData.directions %></textarea>
      </label>

      <label>
        Reference Code
        <span class="editor-label">reference.<%= formData.language === 'python' ? 'py' : 'js' %></span>
        <textarea
          name="referenceCode"
          rows="12"
          required
          data-code-editor="true"
          data-editor-height="280"
          placeholder="Paste a known-correct implementation here."
        ><%= formData.referenceCode %></textarea>
      </label>

      <label>
        Optional Example Description
        <input
          type="text"
          name="exampleDescription"
          value="<%= formData.exampleDescription %>"
          placeholder="Ex: Typical sample input from the assignment prompt"
        />
      </label>

      <label>
        Optional Example Input JSON
        <textarea
          name="exampleInputJson"
          rows="4"
          placeholder='Ex: {"arr":[2,7,11,15],"target":9}'
        ><%= formData.exampleInputJson %></textarea>
      </label>

      <label>
        Student Code (optional to test generated cases)
        <span class="editor-label">student.<%= formData.language === 'python' ? 'py' : 'js' %></span>
        <textarea
          name="candidateCode"
          rows="12"
          data-code-editor="true"
          data-editor-height="280"
          placeholder="Paste student/candidate solution here to run pass/fail checks."
        ><%= formData.candidateCode %></textarea>
      </label>

      <label class="checkbox-row">
        <span>Run student code against generated tests</span>
        <input
          type="checkbox"
          name="runCandidateEnabled"
          value="yes"
          <%= formData.runCandidateEnabled ? 'checked' : '' %>
        />
      </label>

      <button type="submit">Generate Suite</button>
    </form>
  </article>

  <article class="card result-card reveal">
    <h2>Generated Output</h2>

    <% if (!result) { %>
    <p class="muted">
      Your generated suite will appear here. You can copy JSON or download it after generation.
    </p>
    <% } else { %>
    <div class="meta-block">
      <p><strong>Model:</strong> <%= result.metadata.inferredInputModel %></p>
      <p><strong>Generated:</strong> <%= result.metadata.generatedCount %> test cases</p>
      <p><strong>Hints:</strong> <%= result.metadata.constraintHints.join(', ') || 'none' %></p>
      <% if (result.execution && result.execution.enabled) { %>
      <p><strong>Runner:</strong> <%= result.metadata.language %> / function <%= result.execution.functionName %></p>
      <p><strong>Execution:</strong> <%= result.execution.successCount %> passed, <%= result.execution.failedCount %> failed</p>
      <% } %>
    </div>

    <p class="warning-note"><%= result.metadata.note %></p>
    <% if (result.execution && result.execution.enabled) { %>
    <p class="warning-note"><%= result.execution.warning %></p>
    <% } %>

    <% if (result.studentEvaluation && result.studentEvaluation.enabled) { %>
    <section class="student-summary">
      <h3>Student Code Results</h3>
      <p>
        <strong>Pass:</strong> <%= result.studentEvaluation.passCount %> |
        <strong>Fail:</strong> <%= result.studentEvaluation.failCount %> |
        <strong>Runtime Errors:</strong> <%= result.studentEvaluation.errorCount %>
      </p>
      <p class="warning-note"><%= result.studentEvaluation.note %></p>
    </section>
    <% } %>

    <section class="student-retest">
      <h3>Retest With New Student Code</h3>
      <p>Paste updated code and re-run against the same generated suite without regenerating tests.</p>
      <form method="post" action="/dashboard/retest" class="stack-form">
        <label>
          Function Name
          <input
            type="text"
            name="functionName"
            value="<%= formData.functionName %>"
            placeholder="solve"
          />
        </label>
        <label>
          Student Code
          <span class="editor-label">retest.<%= formData.language === 'python' ? 'py' : 'js' %></span>
          <textarea
            name="candidateCode"
            rows="10"
            required
            data-code-editor="true"
            data-editor-height="240"
            placeholder="Paste new student code to retest quickly."
          ><%= formData.candidateCode %></textarea>
        </label>
        <button type="submit">Retest Existing Cases</button>
      </form>
    </section>

    <% if (result.exampleRun) { %>
    <section class="example-run">
      <h3>Example Run</h3>
      <p><strong>Description:</strong> <%= result.exampleRun.description %></p>
      <p class="mini-label">Input</p>
      <pre><%= JSON.stringify(result.exampleRun.input, null, 2) %></pre>
      <p class="mini-label">Output</p>
      <% if (result.exampleRun.error) { %>
      <pre><%= result.exampleRun.error %></pre>
      <% } else { %>
      <pre><%= JSON.stringify(result.exampleRun.output, null, 2) %></pre>
      <% } %>
    </section>
    <% } %>

    <section class="case-list">
      <h3>Per-Test Inputs and Outputs</h3>
      <% result.testCases.forEach((testCase) => { %>
      <details class="case-item">
        <summary>
          <strong><%= testCase.id %></strong> - <%= testCase.category %>
        </summary>
        <p class="mini-label">Input</p>
        <pre><%= JSON.stringify(testCase.input, null, 2) %></pre>
        <p class="mini-label">Output</p>
        <% if (testCase.executionError) { %>
        <pre><%= testCase.executionError %></pre>
        <% } else { %>
        <pre><%= JSON.stringify(testCase.actualOutput, null, 2) %></pre>
        <% } %>

        <% if (result.studentEvaluation && result.studentEvaluation.enabled) { %>
        <p class="mini-label">Student Output</p>
        <% if (testCase.studentError) { %>
        <pre><%= testCase.studentError %></pre>
        <% } else { %>
        <pre><%= JSON.stringify(testCase.studentOutput, null, 2) %></pre>
        <% } %>

        <p class="mini-label">Result</p>
        <% if (!testCase.expectedReady) { %>
        <p class="result-chip fail-chip">Unverifiable (missing expected output)</p>
        <% } else if (testCase.studentPass) { %>
        <p class="result-chip pass-chip">PASS</p>
        <% } else { %>
        <p class="result-chip fail-chip">FAIL</p>
        <% } %>
        <% } %>
      </details>
      <% }) %>
    </section>

    <div class="action-row">
      <button type="button" id="copyJsonButton">Copy JSON</button>
      <button type="button" id="downloadJsonButton" class="ghost-button">Download JSON</button>
    </div>

    <pre id="jsonOutput"><%= JSON.stringify(result, null, 2) %></pre>
    <% } %>
  </article>
</section>
<%- include("partials/footer") %>
