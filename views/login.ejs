<%- include("partials/header", { title, isAuthenticated }) %>
<section class="card auth-card">
  <h2>Administrator Login</h2>
  <p>
    Sign in with your admin credentials to build robust test suites from problem instructions
    and reference code.
  </p>

  <% if (error) { %>
  <div class="alert"><%= error %></div>
  <% } %>

  <form method="post" action="/login" class="stack-form">
    <label>
      Email
      <input type="email" name="email" required value="<%= submittedEmail %>" />
    </label>

    <label>
      Password
      <input type="password" name="password" required />
    </label>

    <button type="submit">Sign In</button>
  </form>
</section>
<%- include("partials/footer") %>
